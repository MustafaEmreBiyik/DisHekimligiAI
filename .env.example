# DentAI Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================
# Backend Configuration
# ============================================================

# JWT Secret Key - CHANGE THIS IN PRODUCTION
DENTAI_SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT Token expiration time in minutes
DENTAI_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database URL
# For SQLite (development):
DATABASE_URL=sqlite:///db/runtime/dentai_app.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql://dentai:dentai_password@postgres:5432/dentai_db

# API Keys
GEMINI_API_KEY=your-gemini-api-key
HUGGINGFACE_API_KEY=your-huggingface-api-key

# Development Mode - set to true for hot reload
DEVELOPMENT_MODE=false

# ============================================================
# Frontend Configuration
# ============================================================

# API URL for frontend (used at runtime)
NEXT_PUBLIC_API_URL=http://backend:8000

# ============================================================
# PostgreSQL Configuration (if using postgres profile)
# ============================================================

POSTGRES_USER=dentai
POSTGRES_PASSWORD=dentai_password
POSTGRES_DB=dentai_db

# ============================================================
# Docker Compose Settings
# ============================================================

# Set to 'true' for development with hot reload
COMPOSE_PROFILES=dev
