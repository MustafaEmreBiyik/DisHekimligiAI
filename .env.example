# DentAI backend security settings
# Copy this file to .env and set secure values for local development.

# Required: JWT signing secret for auth token creation/validation
DENTAI_SECRET_KEY=replace-with-a-long-random-secret

# Optional: access token TTL in minutes (default: 1440)
DENTAI_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI provider keys (optional for non-chat tests)
GEMINI_API_KEY=
HUGGINGFACE_API_KEY=
